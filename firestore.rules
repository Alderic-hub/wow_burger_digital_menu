rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net Default Deny Catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Primordial Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // 3. Schema/Type Validation Helpers
    function isValidMenuItem(data) {
      return data.keys().hasAll(['id', 'name', 'price', 'category', 'image'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 128
        && data.price is number && data.price >= 0 && data.price <= 100000
        && data.category is string && data.category.size() <= 128
        && data.image is string && data.image.size() <= 2048
        && (!data.keys().contains('ingredients') || (data.ingredients is string && data.ingredients.size() <= 4096))
        && (!data.keys().contains('description') || (data.description is string && data.description.size() <= 4096))
        && (!data.keys().contains('prepTime') || (data.prepTime is string && data.prepTime.size() <= 128))
        && (!data.keys().contains('calories') || (data.calories is string && data.calories.size() <= 128))
        && (!data.keys().contains('rating') || (data.rating is number && data.rating >= 0 && data.rating <= 5))
        && (!data.keys().contains('isPopular') || (data.isPopular is bool))
        && (!data.keys().contains('isChefPick') || (data.isChefPick is bool))
        && (!data.keys().contains('isFeatured') || (data.isFeatured is bool));
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['id', 'label'])
        && data.id is string && data.id.size() <= 128
        && data.label is string && data.label.size() > 0 && data.label.size() <= 64
        && (!data.keys().contains('iconName') || (data.iconName is string && data.iconName.size() <= 128))
        && (!data.keys().contains('thumbnail') || (data.thumbnail is string && data.thumbnail.size() <= 2048));
    }

    function isValidRestaurantInfo(data) {
      return (!data.keys().contains('mission') || (data.mission is string && data.mission.size() <= 4096))
        && (!data.keys().contains('journeyFounder') || (data.journeyFounder is string && data.journeyFounder.size() <= 4096))
        && (!data.keys().contains('journeyQuality') || (data.journeyQuality is string && data.journeyQuality.size() <= 4096))
        && (!data.keys().contains('journeyDough') || (data.journeyDough is string && data.journeyDough.size() <= 4096))
        && (!data.keys().contains('openingHours') || (data.openingHours is string && data.openingHours.size() <= 256))
        && (!data.keys().contains('kitchenLastOrder') || (data.kitchenLastOrder is string && data.kitchenLastOrder.size() <= 256))
        && (!data.keys().contains('locationName') || (data.locationName is string && data.locationName.size() <= 256))
        && (!data.keys().contains('locationAddress') || (data.locationAddress is string && data.locationAddress.size() <= 512))
        && (!data.keys().contains('phone') || (data.phone is string && data.phone.size() <= 64))
        && (!data.keys().contains('email') || (data.email is string && data.email.size() <= 256))
        && (!data.keys().contains('instagram') || (data.instagram is string && data.instagram.size() <= 512))
        && (!data.keys().contains('facebook') || (data.facebook is string && data.facebook.size() <= 512))
        && (!data.keys().contains('tiktok') || (data.tiktok is string && data.tiktok.size() <= 512))
        && (!data.keys().contains('telegram') || (data.telegram is string && data.telegram.size() <= 512));
    }

    // 4. Secure Match Blocks for each collection

    // Menu Item Collection
    match /menu/{itemId} {
      allow read: if true; // Publicly accessible to handle high-frequency customer scans
      allow create: if isAdmin() && isValidId(itemId) && isValidMenuItem(incoming());
      allow update: if isAdmin() && isValidMenuItem(incoming());
      allow delete: if isAdmin();
    }

    // Categories Collection
    match /categories/{categoryId} {
      allow read: if true; // Publicly browsable
      allow create: if isAdmin() && isValidId(categoryId) && isValidCategory(incoming());
      allow update: if isAdmin() && isValidCategory(incoming());
      allow delete: if isAdmin();
    }

    // Restaurant Info Sub-documents
    match /restaurant/{infoDocId} {
      allow read: if true; // Publicly viewable contact details / sensory stories
      allow create: if isAdmin() && isValidId(infoDocId) && isValidRestaurantInfo(incoming());
      allow update: if isAdmin() && isValidRestaurantInfo(incoming());
      allow delete: if isAdmin();
    }

    // Admins Reference Collection
    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
      allow write: if false; // Only bootstrapped via safe console or system triggers
    }
  }
}
